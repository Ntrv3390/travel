PORT=8080
DB_HOST=db-master
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=travel_db
DB_SSLMODE=disable

HEADOUT_API_KEY=your_api_key_here
HEADOUT_ENV=sandbox
# Optional explicit override. Leave blank to use HEADOUT_ENV mapping.
HEADOUT_URL=
HEADOUT_SANDBOX_BASE_URL=https://sandbox.api.dev-headout.com/api/public
HEADOUT_STAGE_BASE_URL=https://sandbox.api.dev-headout.com/api/public
HEADOUT_PROD_BASE_URL=https://www.headout.com/api/public

ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
WEB_PORT=3000
API_PORT=8080

# ─── GTTD Dev SFTP ─────────────────────────────────────────
GTTD_DEV_SFTP_HOST=sftp-dev.things-to-do.google.com
GTTD_DEV_SFTP_PORT=22
GTTD_DEV_SFTP_USERNAME=traviia-dev
GTTD_DEV_SFTP_REMOTE_DIR=/uploads/traviia
GTTD_DEV_SSH_PRIVATE_KEY_PATH=/run/secrets/gttd_dev_ssh_key

# ─── GTTD Production SFTP ──────────────────────────────────
GTTD_PROD_SFTP_HOST=sftp.things-to-do.google.com
GTTD_PROD_SFTP_PORT=22
GTTD_PROD_SFTP_USERNAME=traviia-prod
GTTD_PROD_SFTP_REMOTE_DIR=/uploads/traviia
GTTD_PROD_SSH_PRIVATE_KEY_PATH=/run/secrets/gttd_prod_ssh_key

# ─── Feed Generation ────────────────────────────────────────
GTTD_FEED_OUTPUT_DIR=/tmp/gttd_feeds
GTTD_MAX_PRODUCTS_PER_SHARD=500
GTTD_BASE_URL=https://traviia.com

# ─── Feed Upload Schedule ───────────────────────────────────
GTTD_CRON_SCHEDULE=0 2 * * *
GTTD_ENV=production

# JWT
JWT_SECRET=triipzy-jwt-secret-change-in-production

# ─── Sync Worker Pool ─────────────────────────────────────
# Number of concurrent workers for product sync (default: 20)
SYNC_WORKER_COUNT=20
# Headout API rate limit: requests per second (default: 10)
SYNC_RATE_LIMIT_PER_SEC=10
# Rate limit burst size - allows short spikes (default: 20)
SYNC_RATE_BURST=20
# Max retries for failed API calls (default: 3)
SYNC_MAX_RETRIES=3
# Base delay in ms for exponential backoff (default: 500)
SYNC_RETRY_BASE_DELAY_MS=500

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@triipzy.com
ADMIN_EMAIL=

# ─── Server ─────────────────────────────────────────────────
PORT=8080
ENV=development

# ─── Database ────────────────────────────────────────────────
DB_HOST=db-master
DB_PORT=5432
DB_USER=postgres
# REQUIRED — app will not start if blank
DB_PASSWORD=changeme
DB_NAME=travel_db
DB_SSLMODE=disable

# ─── JWT / Auth ──────────────────────────────────────────────
# REQUIRED — app will not start if blank. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret

# Initial password for seeded admin accounts (default: "admin" if unset)
INITIAL_ADMIN_PASSWORD=

# API key required for the /admin/* routes from external callers
ADMIN_API_KEY=

# ─── CORS ────────────────────────────────────────────────────
# REQUIRED — app will not start if blank. Set to your frontend origin.
FRONTEND_URL=http://localhost:3000
# Alternatively, set NEXT_PUBLIC_SITE_URL (checked as fallback)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Admin ───────────────────────────────────────────────────
# Base URL used in admin notification email links (defaults to http://localhost:3000)
ADMIN_BASE_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com

# ─── Headout API ─────────────────────────────────────────────
HEADOUT_API_KEY=your_api_key_here
# sandbox | production
HEADOUT_ENV=sandbox
# Optional explicit override. Leave blank to use HEADOUT_ENV mapping.
HEADOUT_URL=
HEADOUT_SANDBOX_BASE_URL=https://sandbox.api.dev-headout.com/api/public
HEADOUT_STAGE_BASE_URL=https://sandbox.api.dev-headout.com/api/public
HEADOUT_PROD_BASE_URL=https://www.headout.com/api/public

# ─── SMTP (Gmail example) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ─── Frontend (Next.js) ──────────────────────────────────────
# Public API base URL consumed by the browser
NEXT_PUBLIC_API_URL=http://localhost:8080
# Server-side API base URL (used in Next.js API routes / RSC)
API_URL=http://localhost:8080
# Public Headout API base URL for client-side calls (if any)
NEXT_PUBLIC_HEADOUT_PUBLIC_API_URL=https://sandbox.api.dev-headout.com/api/public
HEADOUT_PUBLIC_API_URL=https://sandbox.api.dev-headout.com/api/public

# Exposed ports (docker-compose)
WEB_PORT=3000
API_PORT=8080

# ─── Sync Worker Pool ────────────────────────────────────────
# Number of concurrent workers for product sync
SYNC_WORKER_COUNT=30
# Headout API rate limit: requests per second (0 = unlimited)
SYNC_RATE_LIMIT_PER_SEC=0
SYNC_RATE_BURST=0
SYNC_MAX_RETRIES=0
SYNC_RETRY_BASE_DELAY_MS=0
# Availability sync cron schedule (default: every hour)
AVAILABILITY_SYNC_CRON_SCHEDULE=0 * * * *

# ─── GTTD Feed ───────────────────────────────────────────────
GTTD_BASE_URL=https://traviia.com
GTTD_FEED_OUTPUT_DIR=/tmp/gttd_feeds
GTTD_MAX_PRODUCTS_PER_SHARD=500
GTTD_CRON_SCHEDULE=0 2 * * *
# development | production
GTTD_ENV=production

# ─── GTTD Dev SFTP ───────────────────────────────────────────
GTTD_DEV_SFTP_HOST=sftp-dev.things-to-do.google.com
GTTD_DEV_SFTP_PORT=22
GTTD_DEV_SFTP_USERNAME=traviia-dev
GTTD_DEV_SFTP_REMOTE_DIR=/uploads/traviia
GTTD_DEV_SSH_PRIVATE_KEY_PATH=/run/secrets/gttd_dev_ssh_key

# ─── GTTD Production SFTP ────────────────────────────────────
GTTD_PROD_SFTP_HOST=sftp.things-to-do.google.com
GTTD_PROD_SFTP_PORT=22
GTTD_PROD_SFTP_USERNAME=traviia-prod
GTTD_PROD_SFTP_REMOTE_DIR=/uploads/traviia
GTTD_PROD_SSH_PRIVATE_KEY_PATH=/run/secrets/gttd_prod_ssh_key

EXCHANGE_RATE_API_KEY=